# ─────────────────────────────────────────────
# Banco de dados — Neon (cloud PostgreSQL)
#
# Copie a connection string no painel do Neon:
#   Projeto → Connection Details → JDBC
#
# Use o endpoint com pooler para produção:
#   ep-<name>-pooler.<region>.aws.neon.tech
#
# Use o endpoint direto para desenvolvimento:
#   ep-<name>.<region>.aws.neon.tech
# ─────────────────────────────────────────────
DB_URL=jdbc:postgresql://ep-<name>.<region>.aws.neon.tech/<database>?sslmode=require
DB_USER=<usuario>
DB_PASSWORD=<senha>

# ─────────────────────────────────────────────
# JWT — obrigatório, mínimo 32 caracteres
# ─────────────────────────────────────────────
JWT_SECRET=troque-por-uma-chave-aleatoria-de-pelo-menos-32-chars
JWT_EXPIRATION_MS=86400000

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────────
# Google Maps (necessário apenas no Sprint 4)
# ─────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=sua_chave_aqui
